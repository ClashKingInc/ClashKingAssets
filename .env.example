# Optional: local APK file path used by update_static.py
APK_PATH='C:\path\to\your\Clash of Clans.apk'

# Optional: provide one of these to skip fingerprint lookup from APK
# SHA is supported as alias.
SHA=''
FINGERPRINT=''

# Optional: cache downloaded static files per fingerprint for faster re-runs.
# 1=true (default), 0=false
USE_DOWNLOAD_CACHE='1'

# Optional: ignore cache for this run and re-download files.
# 1=true, 0=false (default)
FORCE_DOWNLOAD_REFRESH='0'
